# =========================================================
# Full-Stack Java + Spring Boot + React + MongoDB .gitignore
# Suitable for Maven, Java 21, Spring Boot, React/Vite, testing,
# packaging, local config, Docker, logs, and common IDEs.
# =========================================================

# ---------------------------------------------------------
# Operating system files
# ---------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---------------------------------------------------------
# Java / JVM build output
# ---------------------------------------------------------
*.class
*.log
*.ctxt
hs_err_pid*
replay_pid*

# ---------------------------------------------------------
# Maven
# ---------------------------------------------------------
target/
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# Keep Maven wrapper scripts and properties tracked when generated by Spring Initializr.
# Do NOT ignore:
# mvnw
# mvnw.cmd
# .mvn/wrapper/maven-wrapper.properties

# ---------------------------------------------------------
# Gradle - included only in case students experiment later
# ---------------------------------------------------------
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar

# ---------------------------------------------------------
# Spring Boot generated / local files
# ---------------------------------------------------------
*.jar
*.war
*.ear
application-local.properties
application-local.yml
application-dev-local.properties
application-dev-local.yml
application-secrets.properties
application-secrets.yml

# Keep normal application config tracked if it contains no secrets.
# application.properties
# application.yml

# ---------------------------------------------------------
# Environment variables and secrets
# ---------------------------------------------------------
.env
.env.*
!.env.example
*.env
*.pem
*.key
*.crt
*.p12
*.jks
*.keystore
secrets/
secret/
credentials/
credentials.json
service-account.json

# ---------------------------------------------------------
# MongoDB local data / dumps / seed scratch files
# ---------------------------------------------------------
data/
db/
mongodb-data/
mongo-data/
dump/
*.bson
*.wt
*.mongodump

# Keep curated seed files if intentionally created for class.
# Example:
# !src/main/resources/seed-data/*.json

# ---------------------------------------------------------
# Logs, reports, runtime files
# ---------------------------------------------------------
logs/
*.log
*.log.*
log/
reports/
run/
*.pid
*.seed

# ---------------------------------------------------------
# Test reports and coverage
# ---------------------------------------------------------
surefire-reports/
failsafe-reports/
coverage/
.coverage/
.jacoco/
jacoco.exec
*.exec

# ---------------------------------------------------------
# IDEs and editors
# ---------------------------------------------------------
.idea/
*.iws
*.iml
*.ipr
.vscode/
.project
.classpath
.settings/
.springBeans
.sts4-cache/
.factorypath
.zed

# ---------------------------------------------------------
# VS Code Java / language server
# ---------------------------------------------------------
bin/
.settings/
.metadata/

# ---------------------------------------------------------
# Node / React frontend
# ---------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# React / Vite build outputs
dist/
build/
.vite/

# Frontend coverage and cache
coverage/
.nyc_output/
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# ---------------------------------------------------------
# Package manager lock files
# ---------------------------------------------------------
# For teaching, it is usually better to COMMIT lock files for reproducible installs.
# Do NOT ignore these unless you deliberately choose otherwise:
# package-lock.json
# pnpm-lock.yaml
# yarn.lock

# ---------------------------------------------------------
# Docker / container local overrides
# ---------------------------------------------------------
.docker/
docker-compose.override.yml
compose.override.yml

# Keep main Docker files tracked when created.
# Dockerfile
# docker-compose.yml
# compose.yml

# ---------------------------------------------------------
# API client scratch files
# ---------------------------------------------------------
*.http.env.json
.http-local/

# Keep request collections tracked if they are part of class material.
# requests/*.http

# ---------------------------------------------------------
# Temporary files
# ---------------------------------------------------------
*.tmp
*.temp
*.swp
*.swo
*~
.cache/
tmp/
temp/

# ---------------------------------------------------------
# AI assistant / local scratch output
# ---------------------------------------------------------
.ai-cache/
.ai-output/
prompts/private/
private-notes/

# ---------------------------------------------------------
# Misc generated files
# ---------------------------------------------------------
out/
.generated/
generated/
.java-version # jenv